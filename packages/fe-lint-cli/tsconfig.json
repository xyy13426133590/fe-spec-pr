{
    "compilerOptions": {
        "outDir": "./lib",
        "target": "es5",
        "module": "commonjs",
        "esModuleInterop": true,
        "removeComments": true,
        "resolveJsonModule": true,
        "declaration": true,
        "downlevelIteration": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["src"]
}